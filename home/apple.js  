/* Apple-style enhancements: topbar, dock, scroll reveal, live clock */

(function () {
  const isRu = (localStorage.getItem('home_lang') || 'ru') === 'ru';
  const t = (ru, en) => (isRu ? ru : en);

  // === TOP BAR ===
  const topbar = document.createElement('div');
  topbar.className = 'apple-topbar';
  topbar.innerHTML = `
    <div class="apple-traffic"><span></span><span></span><span></span></div>
    <div class="apple-menu">
      <span>BezzubickMCPlay</span>
      <span>${t('Файл', 'File')}</span>
      <span>${t('Правка', 'Edit')}</span>
      <span>${t('Вид', 'View')}</span>
      <span>${t('Окно', 'Window')}</span>
      <span>${t('Помощь', 'Help')}</span>
    </div>
    <div class="apple-clock" id="apple-clock"></div>
  `;
  document.body.prepend(topbar);

  // === LIVE CLOCK ===
  const clockEl = document.getElementById('apple-clock');
  const fmt = () => {
    const d = new Date();
    const days = isRu
      ? ['Вс','Пн','Вт','Ср','Чт','Пт','Сб']
      : ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const months = isRu
      ? ['янв','фев','мар','апр','мая','июн','июл','авг','сен','окт','ноя','дек']
      : ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const hh = String(d.getHours()).padStart(2, '0');
    const mm = String(d.getMinutes()).padStart(2, '0');
    return `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}  ${hh}:${mm}`;
  };
  const tick = () => { if (clockEl) clockEl.textContent = fmt(); };
  tick();
  setInterval(tick, 1000 * 30);

  // === DOCK ===
  const dock = document.createElement('nav');
  dock.className = 'apple-dock';
  dock.innerHTML = `
    <a class="apple-dock-item" href="#" data-label="${t('Главная','Home')}" data-scroll="hero">
      <span class="material-symbols-outlined">home</span>
    </a>
    <a class="apple-dock-item" href="#" data-label="${t('Лента','Timeline')}" data-scroll="about-card">
      <span class="material-symbols-outlined">timeline</span>
    </a>
    <a class="apple-dock-item" href="#" data-label="${t('Календарь','Calendar')}" data-scroll="calendar">
      <span class="material-symbols-outlined">calendar_month</span>
    </a>
    <a class="apple-dock-item" href="#" data-label="${t('Скин','Skin')}" data-scroll="skin">
      <span class="material-symbols-outlined">person</span>
    </a>
    <a class="apple-dock-item" href="#" data-label="${t('Видео','Videos')}" data-scroll="videos-title">
      <span class="material-symbols-outlined">play_circle</span>
    </a>
    <a class="apple-dock-item" href="./links/" data-label="${t('Ссылки','Links')}">
      <span class="material-symbols-outlined">link</span>
    </a>
  `;
  document.body.appendChild(dock);

  // Smooth scroll for dock items
  dock.querySelectorAll('[data-scroll]').forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const target = item.dataset.scroll;
      const el =
        document.getElementById(target) ||
        document.querySelector(`.${target}`);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // === SCROLL REVEAL ===
  const revealSelectors = ['.card', '#carousel > *', '#timeline details'];
  const targets = new Set();
  revealSelectors.forEach(sel => {
    document.querySelectorAll(sel).forEach(el => targets.add(el));
  });

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(en => {
        if (en.isIntersecting) {
          en.target.classList.add('is-visible');
          io.unobserve(en.target);
        }
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );

  const observeAll = () => {
    targets.forEach(el => {
      if (!el.classList.contains('apple-reveal')) {
        el.classList.add('apple-reveal');
        io.observe(el);
      }
    });
  };
  observeAll();

  // Re-observe new nodes (timeline/videos render after data load)
  const mo = new MutationObserver(() => {
    revealSelectors.forEach(sel => {
      document.querySelectorAll(sel).forEach(el => {
        if (!el.classList.contains('apple-reveal')) {
          el.classList.add('apple-reveal');
          io.observe(el);
        }
      });
    });
  });
  mo.observe(document.body, { childList: true, subtree: true });
})();

